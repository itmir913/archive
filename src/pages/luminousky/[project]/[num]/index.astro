---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('luminousky', ({ data }) => !data.draft);
  posts.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

  return posts.map((post) => {
    const [project, num] = post.slug.split('/');

    const projectPosts = posts.filter((p) => p.slug.split('/')[0] === project);
    const idx = projectPosts.findIndex((p) => p.slug === post.slug);

    return {
      params: { project, num },
      props: {
        post,
        prevPost: idx > 0 ? projectPosts[idx - 1] : null,
        nextPost: idx < projectPosts.length - 1 ? projectPosts[idx + 1] : null,
      },
    };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await post.render();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function formatDate(d: Date) {
  return d.toLocaleDateString('ko-KR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'Asia/Seoul',
  });
}

function postUrl(p: typeof post) {
  const [proj, n] = p.slug.split('/');
  return `${base}/luminousky/${proj}/${n}/`;
}
---

<BaseLayout
  title={post.data.title}
  description={post.data.description || post.data.title}
  ogType="article"
  section="archive"
>
  <div class="max-w-2xl mx-auto">

    <a
      href={`${base}/luminousky/`}
      data-pagefind-ignore
      class="inline-block text-base text-gray-400 mb-8 no-underline hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
    >
      ← luminousky
    </a>

    <header class="mb-10" data-pagefind-ignore>
      <h1 class="text-3xl font-bold leading-tight tracking-tight m-0 mb-5 text-gray-900 dark:text-gray-100">
        {post.data.title}
      </h1>
      <div class="flex flex-wrap items-center gap-3 text-base text-gray-400">
        <time datetime={post.data.date.toISOString()}>
          {formatDate(post.data.date)}
        </time>
        <span aria-hidden="true">·</span>
        <span class="text-violet-500">{post.data.project}</span>
      </div>
      {post.data.description && (
        <p class="mt-4 mb-0 text-lg text-gray-500 dark:text-gray-400 leading-relaxed border-l-2 border-gray-200 dark:border-gray-700 pl-4">
          {post.data.description}
        </p>
      )}
    </header>

    <div class="prose prose-gray dark:prose-invert max-w-none" data-pagefind-body>
      <Content />
    </div>

    {(prevPost || nextPost) && (
      <nav class="mt-12 pt-8 border-t border-gray-100 dark:border-gray-800 grid grid-cols-1 sm:grid-cols-2 gap-3" data-pagefind-ignore>
        <div>
          {prevPost && (
            <a
              href={postUrl(prevPost)}
              class="group flex flex-col gap-1 no-underline p-4 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-blue-200 dark:hover:border-blue-800 hover:bg-blue-50/40 dark:hover:bg-blue-950/40 transition-all"
            >
              <span class="text-base text-gray-400 group-hover:text-blue-500 transition-colors">← 이전</span>
              <span class="text-base font-semibold text-gray-900 dark:text-gray-100 group-hover:text-blue-700 dark:group-hover:text-blue-300 transition-colors line-clamp-2 leading-snug">
                {prevPost.data.title}
              </span>
            </a>
          )}
        </div>
        <div>
          {nextPost && (
            <a
              href={postUrl(nextPost)}
              class="group flex flex-col gap-1 no-underline p-4 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-blue-200 dark:hover:border-blue-800 hover:bg-blue-50/40 dark:hover:bg-blue-950/40 transition-all sm:text-right"
            >
              <span class="text-base text-gray-400 group-hover:text-blue-500 transition-colors">다음 →</span>
              <span class="text-base font-semibold text-gray-900 dark:text-gray-100 group-hover:text-blue-700 dark:group-hover:text-blue-300 transition-colors line-clamp-2 leading-snug">
                {nextPost.data.title}
              </span>
            </a>
          )}
        </div>
      </nav>
    )}

  </div>
</BaseLayout>
