---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('luminousky', ({ data }) => !data.draft);
allPosts.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const byProject = new Map<string, typeof allPosts>();
const projectNames = new Map<string, string>();

for (const post of allPosts) {
  const projectSlug = post.slug.split('/')[0];
  if (!byProject.has(projectSlug)) byProject.set(projectSlug, []);
  byProject.get(projectSlug)!.push(post);
  if (!projectNames.has(projectSlug)) projectNames.set(projectSlug, post.data.project);
}

const projects = [...byProject.keys()].sort((a, b) => {
  return byProject.get(a)![0].data.date.getTime() - byProject.get(b)![0].data.date.getTime();
});

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    timeZone: 'Asia/Seoul',
  });
}
---

<BaseLayout title="luminousky" section="archive" pagefindIgnore>
  <div class="mb-10">
    <p class="text-base text-violet-500 font-medium m-0 mb-2">Chapter 2</p>
    <h1 class="text-4xl font-bold tracking-tight m-0 mb-3">luminousky</h1>
    <p class="text-base text-gray-400 m-0">
      {allPosts.length > 0
        ? `${allPosts.length}개 기록 · ${projects.length}개 프로젝트`
        : '기록 준비 중'}
    </p>
  </div>

  {allPosts.length === 0 ? (
    <p class="text-base text-gray-400">아직 게시된 기록이 없습니다.</p>
  ) : (
    <>
      <div class="mb-8 rounded-2xl border border-gray-200 dark:border-gray-800 overflow-hidden">
        <div class="px-4 py-3 flex flex-wrap gap-1.5">
          <button
            data-proj="__all__"
            type="button"
            class="filter-proj-btn text-base px-3 py-1 rounded-full border border-gray-200 dark:border-gray-700 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:border-gray-400 dark:hover:border-gray-500 transition-colors cursor-pointer whitespace-nowrap"
          >
            전체
          </button>
          {projects.map((slug) => (
            <button
              data-proj={slug}
              type="button"
              class="filter-proj-btn text-base px-3 py-1 rounded-full border border-gray-200 dark:border-gray-700 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:border-gray-400 dark:hover:border-gray-500 transition-colors cursor-pointer whitespace-nowrap"
            >
              {projectNames.get(slug)}<span class="ml-1.5 text-gray-300 dark:text-gray-600">{byProject.get(slug)!.length}</span>
            </button>
          ))}
        </div>
      </div>

      <div id="browse-view">
        {projects.map((projectSlug) => {
          const posts = byProject.get(projectSlug)!;
          const displayName = projectNames.get(projectSlug)!;
          return (
            <section
              class="project-section mb-12"
              data-proj={projectSlug}
            >
              <div class="flex items-center gap-3 mb-4">
                <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 m-0">{displayName}</h2>
                <span class="text-base text-gray-400 font-normal">{posts.length}</span>
                <div class="flex-1 h-px bg-gray-100 dark:bg-gray-800"></div>
              </div>
              <ul class="list-none p-0 m-0">
                {posts.map((post) => {
                  const [projSlug, num] = post.slug.split('/');
                  return (
                    <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-6 py-3.5 border-b border-gray-100 dark:border-gray-800 last:border-b-0">
                      <span class="sm:w-20 sm:flex-shrink-0 text-base text-gray-400 tabular-nums pt-px">
                        {formatDate(post.data.date)}
                      </span>
                      <div class="flex-1 min-w-0">
                        <a
                          href={`${base}/luminousky/${projSlug}/${num}/`}
                          class="text-base font-semibold text-gray-900 dark:text-gray-100 hover:text-blue-600 dark:hover:text-blue-400 no-underline transition-colors"
                        >
                          {post.data.title}
                        </a>
                        {post.data.description && (
                          <p class="text-base text-gray-400 m-0 mt-0.5 leading-snug">
                            {post.data.description}
                          </p>
                        )}
                      </div>
                    </li>
                  );
                })}
              </ul>
            </section>
          );
        })}
      </div>
    </>
  )}
</BaseLayout>

<style>
  .filter-proj-btn.active {
    @apply bg-violet-600 border-violet-600 text-white;
  }
</style>

<script>
  const projBtns = document.querySelectorAll<HTMLButtonElement>('.filter-proj-btn');
  const projectSections = document.querySelectorAll<HTMLElement>('section.project-section');

  let selectedProj = '__all__';

  function syncUI() {
    projBtns.forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.proj === selectedProj);
    });
  }

  function applyFilter() {
    projectSections.forEach((sec) => {
      const show = selectedProj === '__all__' || sec.dataset.proj === selectedProj;
      (sec as HTMLElement).style.display = show ? '' : 'none';
    });
    syncUI();
  }

  projBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      selectedProj = btn.dataset.proj || '__all__';
      applyFilter();
    });
  });

  syncUI();
</script>
