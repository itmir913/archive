---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { timeline } from '../../data/timeline-curated';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Timeline — luminousky">
  <div class="mb-16">
    <h1 class="text-4xl font-bold tracking-tight m-0 mb-2">Timeline</h1>
    <p class="text-base text-gray-400 m-0">2012 –</p>
  </div>

  <div class="relative">
    <!-- 수직선 -->
    <div class="absolute left-0 top-2 bottom-0 w-px bg-gray-100 hidden sm:block" aria-hidden="true"></div>

    <ol class="list-none p-0 m-0 space-y-16">
      {timeline.map((entry) => (
        <li class="relative sm:pl-10">
          <!-- 점 -->
          <div class="absolute left-0 top-2 w-2 h-2 rounded-full bg-gray-300 -translate-x-[3px] hidden sm:block" aria-hidden="true"></div>

          <!-- 연도 -->
          <p class="text-base font-semibold text-gray-400 tracking-wide m-0 mb-2">{entry.year}</p>

          <!-- 제목 -->
          <h2 class="text-2xl font-bold tracking-tight text-gray-900 m-0 mb-4">{entry.title}</h2>

          <!-- 설명 -->
          <p class="text-base text-gray-600 leading-relaxed m-0 mb-5 max-w-2xl">{entry.description}</p>

          <!-- 변화 -->
          <p class="text-base text-gray-400 leading-relaxed m-0 mb-5 max-w-2xl italic">{entry.whatChanged}</p>

          <!-- 키워드 -->
          <p class="text-base text-gray-400 m-0 mb-5">
            {entry.keywords.join(' · ')}
          </p>

          <!-- 대표 포스트 -->
          {entry.posts.length > 0 && (
            <ul class="list-none p-0 m-0 space-y-1">
              {entry.posts.map((post) => (
                <li>
                  <a
                    href={post.external ? post.href : `${base}${post.href}`}
                    target={post.external ? '_blank' : undefined}
                    rel={post.external ? 'noopener noreferrer' : undefined}
                    class="text-base text-blue-500 hover:text-blue-700 transition-colors no-underline"
                  >
                    → {post.title}{post.external ? ' ↗' : ''}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ol>
  </div>
</BaseLayout>
