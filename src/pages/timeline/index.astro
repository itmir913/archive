---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { timelineExtra } from '../../data/timeline-extra';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Chapter 1: 연도별 집계
const itmir = await getCollection('itmir', ({ data }) => !data.draft);

const catsByYear = new Map<number, Map<string, number>>();
const countByYear = new Map<number, number>();

for (const post of itmir) {
  const year = post.data.date.getFullYear();
  countByYear.set(year, (countByYear.get(year) ?? 0) + 1);
  if (!catsByYear.has(year)) catsByYear.set(year, new Map());
  if (post.data.category) {
    const m = catsByYear.get(year)!;
    m.set(post.data.category, (m.get(post.data.category) ?? 0) + 1);
  }
}

function topCats(year: number, n = 3): string[] {
  const m = catsByYear.get(year) ?? new Map();
  return [...m.entries()].sort((a, b) => b[1] - a[1]).slice(0, n).map(([c]) => c);
}

// Chapter 1 연도 (역순)
const ch1Years = [...countByYear.keys()].sort((a, b) => b - a);

// 공백기 항목 (2022-2025) 통합
const gapItems = timelineExtra.filter((y) => y.chapter === 'gap').flatMap((y) => y.items);

// Chapter 2 연도 (역순)
const ch2Years = timelineExtra
  .filter((y) => y.chapter === 2)
  .sort((a, b) => b.year - a.year);

---

<BaseLayout title="Timeline — luminousky">
  <!-- Hero -->
  <div class="mb-16">
    <h1 class="text-4xl font-bold tracking-tight m-0 mb-2">Timeline</h1>
    <p class="text-base text-gray-400 m-0">2013 –</p>
  </div>

  <!-- Timeline -->
  <div class="relative">

    <!-- Chapter 2 -->
    <div class="mb-2">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-px flex-1 bg-gray-100"></div>
        <span class="text-base font-semibold text-violet-500 tracking-wide">Chapter 2</span>
        <div class="h-px flex-1 bg-gray-100"></div>
      </div>

      {ch2Years.map((yearData) => (
        <div class="flex gap-6 mb-10">
          <div class="w-14 flex-shrink-0 text-right pt-0.5">
            <span class="text-base font-bold text-violet-600">{yearData.year}</span>
          </div>
          <div class="flex flex-col gap-4 flex-1 min-w-0 border-l-2 border-violet-200 pl-6">
            {yearData.items.map((item) => (
              <div>
                <div class="text-base font-semibold text-gray-900 leading-snug mb-1">
                  {item.url ? (
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="no-underline hover:text-violet-600 transition-colors"
                    >
                      {item.title} <span class="text-gray-400">↗</span>
                    </a>
                  ) : item.title}
                </div>
                {item.description && (
                  <p class="text-base text-gray-500 m-0 leading-relaxed">{item.description}</p>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- 공백기 (하나의 블록) -->
    {gapItems.length > 0 && (
      <div class="mb-2">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-px flex-1 bg-gray-100"></div>
          <span class="text-base font-semibold text-gray-400 tracking-wide">2022–2025</span>
          <div class="h-px flex-1 bg-gray-100"></div>
        </div>

        <div class="flex gap-6 mb-10">
          <div class="w-14 flex-shrink-0"></div>
          <div class="flex flex-col gap-4 flex-1 min-w-0 border-l-2 border-gray-200 pl-6">
            {gapItems.map((item) => (
              <div>
                <div class="text-base font-semibold text-gray-600 leading-snug mb-1">
                  {item.url ? (
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="no-underline hover:text-gray-900 transition-colors"
                    >
                      {item.title} <span class="text-gray-400">↗</span>
                    </a>
                  ) : item.title}
                </div>
                {item.description && (
                  <p class="text-base text-gray-400 m-0 leading-relaxed">{item.description}</p>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>
    )}

    <!-- Chapter 1 -->
    <div>
      <div class="flex items-center gap-3 mb-6">
        <div class="h-px flex-1 bg-gray-100"></div>
        <span class="text-base font-semibold text-blue-500 tracking-wide">Chapter 1 · ITMir</span>
        <div class="h-px flex-1 bg-gray-100"></div>
      </div>

      {ch1Years.map((year) => {
        const count = countByYear.get(year)!;
        const cats = topCats(year);
        return (
          <div class="flex gap-6 mb-7">
            <div class="w-14 flex-shrink-0 text-right pt-0.5">
              <span class="text-base font-bold text-gray-400">{year}</span>
            </div>
            <div class="flex-1 min-w-0 border-l-2 border-blue-100 pl-6 pb-1">
              <div class="flex items-baseline gap-3 flex-wrap mb-1">
                <span class="text-base font-semibold text-gray-800">{count}개 포스트</span>
                {cats.length > 0 && (
                  <span class="text-base text-gray-400">{cats.join(' · ')}</span>
                )}
              </div>
              <a
                href={`${base}/itmir/#year-${year}`}
                class="text-base text-blue-500 hover:text-blue-700 transition-colors no-underline"
              >
                {year}년 보기 →
              </a>
            </div>
          </div>
        );
      })}
    </div>

  </div>

</BaseLayout>
