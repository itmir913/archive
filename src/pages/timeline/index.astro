---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { timeline } from '../../data/timeline-curated';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Timeline" section="timeline">
  <div class="mb-16">
    <h1 class="text-4xl font-bold tracking-tight m-0 mb-2">Timeline</h1>
    <p class="text-base text-gray-400 m-0">2012 –</p>
  </div>

  <ol class="list-none p-0 m-0 divide-y divide-gray-100">
    {timeline.map((entry) => (
      <li class="py-12 grid grid-cols-1 sm:grid-cols-[10rem_1fr] gap-2 sm:gap-12">
        <!-- 왼쪽: 연도 -->
        <div class="sm:pt-1.5">
          <p class="text-base font-semibold text-gray-400 tracking-wide m-0">{entry.year}</p>
        </div>

        <!-- 오른쪽: 내용 -->
        <div>
          <h2 class="text-2xl font-bold tracking-tight text-gray-900 m-0 mb-4">{entry.title}</h2>
          <p class="text-base text-gray-600 leading-relaxed m-0 mb-4">{entry.description}</p>
          <p class="text-base text-gray-400 leading-relaxed m-0 mb-4 italic">{entry.whatChanged}</p>
          <p class="text-base text-gray-400 m-0 mb-5">{entry.keywords.join(' · ')}</p>

          {entry.posts.length > 0 && (
            <ul class="list-none p-0 m-0 space-y-1">
              {entry.posts.map((post) => (
                <li>
                  <a
                    href={post.external ? post.href : `${base}${post.href}`}
                    target={post.external ? '_blank' : undefined}
                    rel={post.external ? 'noopener noreferrer' : undefined}
                    class="text-base text-blue-500 hover:text-blue-700 transition-colors no-underline"
                  >
                    → {post.title}{post.external ? ' ↗' : ''}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      </li>
    ))}
  </ol>
</BaseLayout>
