---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { timeline } from '../../data/timeline-curated';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const startYear = timeline[timeline.length - 1].year;
const endYear = timeline[0].year;
const totalPosts = timeline.reduce((sum, e) => sum + e.posts.length, 0);
---

<BaseLayout title="Timeline" section="timeline" pagefindIgnore>
  <div class="mb-16">
    <p class="text-base text-blue-500 font-medium m-0 mb-2">{startYear} – {endYear}</p>
    <h1 class="text-4xl font-bold tracking-tight m-0 mb-3">Timeline</h1>
    <p class="text-base text-gray-400 m-0">{timeline.length}개 에라 · {totalPosts}개 대표 포스트</p>
  </div>

  <div class="relative sm:pl-8">
    <!-- 수직선 -->
    <div class="absolute left-0 top-0 bottom-0 w-px bg-gray-100 dark:bg-gray-800 hidden sm:block" aria-hidden="true"></div>

    <ol class="list-none p-0 m-0">
      {timeline.map((entry) => (
        <li class="relative pb-12 grid grid-cols-1 sm:grid-cols-[10rem_1fr] sm:items-start gap-2 sm:gap-12">
          <!-- 점 -->
          <div class="absolute -left-8 top-2 w-2 h-2 rounded-full bg-gray-300 dark:bg-gray-600 -translate-x-1/2 hidden sm:block" aria-hidden="true"></div>

          <!-- 연도 -->
          <div class="pt-8 sm:pt-0.5">
            <p class="text-base font-semibold text-gray-400 dark:text-gray-500 tracking-wide m-0">{entry.year}</p>
          </div>

          <!-- 내용 -->
          <div>
            <h2 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-gray-100 m-0 mb-3">{entry.title}</h2>
            <p class="text-base text-gray-500 dark:text-gray-400 leading-relaxed m-0 mb-4">{entry.description}</p>
            <p class="text-base text-gray-300 dark:text-gray-600 m-0 mb-5">{entry.keywords.join(' · ')}</p>

            {entry.posts.length > 0 && (
              <ul class="list-none p-0 m-0 space-y-1">
                {entry.posts.map((post) => (
                  <li>
                    <a
                      href={post.external ? post.href : `${base}${post.href}`}
                      target={post.external ? '_blank' : undefined}
                      rel={post.external ? 'noopener noreferrer' : undefined}
                      class="text-base text-blue-500 hover:text-blue-700 dark:hover:text-blue-400 transition-colors no-underline"
                    >
                      → {post.title}{post.external ? ' ↗' : ''}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </li>
      ))}
    </ol>
  </div>
</BaseLayout>
