---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('itmir');
  return posts.map((post) => {
    const [year, post_num] = post.slug.split('/');
    return {
      params: { year, post_num },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await post.render();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function formatDate(d: Date) {
  return d.toLocaleDateString('ko-KR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'Asia/Seoul',
  });
}
---

<BaseLayout title={post.data.title} description={post.data.description || post.data.title}>
  <article>
    <header class="mb-9 pb-6 border-b border-gray-200">
      <a
        href={`${base}/itmir/`}
        class="inline-block text-base text-gray-400 mb-5 no-underline hover:text-blue-600 transition-colors"
      >
        ← 목록으로
      </a>

      <h1 class="text-3xl font-bold leading-tight tracking-tight m-0 mb-3">
        {post.data.title}
      </h1>

      <div class="flex items-center gap-3 flex-wrap">
        <time class="text-base text-gray-400" datetime={post.data.date.toISOString()}>
          {formatDate(post.data.date)}
        </time>
        {post.data.category && (
          <span class="text-base text-gray-400 bg-gray-100 px-2 py-0.5 rounded">
            {post.data.category}
          </span>
        )}
        {post.data.original_url && (
          <a
            href={post.data.original_url}
            class="text-base text-gray-400 underline underline-offset-2"
            target="_blank"
            rel="noopener noreferrer"
          >
            원본 보기 ↗
          </a>
        )}
      </div>

      {post.data.description && (
        <p class="mt-3 mb-0 text-base text-gray-400 leading-relaxed">
          {post.data.description}
        </p>
      )}
    </header>

    <div class="prose prose-gray">
      <Content />
    </div>

    {post.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-8 pt-6 border-t border-gray-200">
        {post.data.tags.map((tag) => (
          <span class="text-base text-gray-400 bg-gray-100 px-2 py-0.5 rounded">
            #{tag}
          </span>
        ))}
      </div>
    )}
  </article>
</BaseLayout>
