---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('itmir');
  posts.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

  return posts.map((post, index) => {
    const [year, post_num] = post.slug.split('/');
    return {
      params: { year, post_num },
      props: {
        post,
        prevPost: index > 0 ? posts[index - 1] : null,
        nextPost: index < posts.length - 1 ? posts[index + 1] : null,
      },
    };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await post.render();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'Asia/Seoul',
  });
}

const prevParts = prevPost ? prevPost.slug.split('/') : null;
const nextParts = nextPost ? nextPost.slug.split('/') : null;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description || post.data.title}
  ogType="article"
  section="archive"
>
  <div class="max-w-2xl mx-auto">

    <!-- 뒤로 (검색 인덱싱 제외) -->
    <a
      href={`${base}/itmir/`}
      data-pagefind-ignore
      class="inline-block text-base text-gray-400 mb-8 no-underline hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
    >
      ← ITMir
    </a>

    <!-- 헤더 -->
    <header class="mb-10" data-pagefind-ignore>
      <h1 class="text-3xl font-bold leading-tight tracking-tight m-0 mb-5 text-gray-900 dark:text-gray-100">
        {post.data.title}
      </h1>
      <div class="flex flex-wrap items-center gap-3 text-base text-gray-400">
        <time datetime={post.data.date.toISOString()}>
          {formatDate(post.data.date)}
        </time>
        {post.data.category && (
          <>
            <span aria-hidden="true">·</span>
            <span>{post.data.category}</span>
          </>
        )}
        {post.data.original_url && (
          <>
            <span aria-hidden="true">·</span>
            <a
              href={post.data.original_url}
              class="text-gray-400 underline underline-offset-2 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
              target="_blank"
              rel="noopener noreferrer"
            >
              Original ↗
            </a>
          </>
        )}
      </div>
      {post.data.description && (
        <p class="mt-4 mb-0 text-lg text-gray-500 dark:text-gray-400 leading-relaxed border-l-2 border-gray-200 dark:border-gray-700 pl-4">
          {post.data.description}
        </p>
      )}
    </header>

    <!-- pagefind 메타 (검색 결과 카드용) -->
    <div class="hidden">
      <span data-pagefind-meta="date">{formatDate(post.data.date)}</span>
      {post.data.category && <span data-pagefind-meta="category">{post.data.category}</span>}
    </div>

    <!-- 본문 (전문 검색 인덱싱 대상) -->
    <div class="prose prose-gray dark:prose-invert max-w-none" data-pagefind-body>
      <Content />
    </div>

    <!-- 태그 -->
    {post.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-10 pt-6 border-t border-gray-100 dark:border-gray-800" data-pagefind-ignore>
        {post.data.tags.map((tag) => (
          <span class="text-base text-gray-400 bg-gray-100 dark:bg-gray-800 px-2.5 py-0.5 rounded-full">
            #{tag}
          </span>
        ))}
      </div>
    )}

    <!-- 이전 / 다음 -->
    {(prevPost || nextPost) && (
      <nav class="mt-12 pt-8 border-t border-gray-100 dark:border-gray-800 grid grid-cols-1 sm:grid-cols-2 gap-3" data-pagefind-ignore>
        <div>
          {prevPost && prevParts && (
            <a
              href={`${base}/itmir/${prevParts[0]}/${prevParts[1]}/`}
              class="group flex flex-col gap-1 no-underline p-4 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-blue-200 dark:hover:border-blue-800 hover:bg-blue-50/40 dark:hover:bg-blue-950/40 transition-all"
            >
              <span class="text-base text-gray-400 group-hover:text-blue-500 transition-colors">
                ← Prev
              </span>
              <span class="text-base font-semibold text-gray-900 dark:text-gray-100 group-hover:text-blue-700 dark:group-hover:text-blue-300 transition-colors line-clamp-2 leading-snug">
                {prevPost.data.title}
              </span>
            </a>
          )}
        </div>
        <div>
          {nextPost && nextParts && (
            <a
              href={`${base}/itmir/${nextParts[0]}/${nextParts[1]}/`}
              class="group flex flex-col gap-1 no-underline p-4 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-blue-200 dark:hover:border-blue-800 hover:bg-blue-50/40 dark:hover:bg-blue-950/40 transition-all sm:text-right"
            >
              <span class="text-base text-gray-400 group-hover:text-blue-500 transition-colors">
                Next →
              </span>
              <span class="text-base font-semibold text-gray-900 dark:text-gray-100 group-hover:text-blue-700 dark:group-hover:text-blue-300 transition-colors line-clamp-2 leading-snug">
                {nextPost.data.title}
              </span>
            </a>
          )}
        </div>
      </nav>
    )}

  </div>
</BaseLayout>
