---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('itmir', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const byYear = new Map<string, typeof allPosts>();
for (const post of allPosts) {
  const year = String(post.data.date.getFullYear());
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(post);
}
const years = [...byYear.keys()].sort((a, b) => Number(b) - Number(a));

const catCounts = new Map<string, number>();
for (const post of allPosts) {
  if (post.data.category) {
    catCounts.set(post.data.category, (catCounts.get(post.data.category) || 0) + 1);
  }
}
const allCategories = [...catCounts.keys()].sort((a, b) => a.localeCompare(b, 'ko'));

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    timeZone: 'Asia/Seoul',
  });
}
---

<BaseLayout title="ITMir Archive" description="657 posts · 2012–2021 · Android, Linux, app development, and everything in between" section="archive" pagefindIgnore>
  <!-- Header -->
  <div class="mb-10">
    <p class="text-base text-blue-500 font-medium m-0 mb-2">Chapter 1</p>
    <h1 class="text-4xl font-bold tracking-tight m-0 mb-3">ITMir</h1>
    <p class="text-base text-gray-400 m-0">
      {allPosts.length} posts · {years.length} years · {allCategories.length} categories
    </p>
  </div>

  <!-- 검색 · 필터 카드 -->
  <div class="mb-6 rounded-2xl border border-gray-200 dark:border-gray-800 overflow-hidden">

    <!-- 검색 -->
    <div class="flex items-center gap-3 px-4">
      <svg class="w-4 h-4 flex-shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
      </svg>
      <input
        type="search"
        id="search-input"
        placeholder="Search (title · content)..."
        autocomplete="off"
        class="flex-1 py-3.5 text-base font-sans bg-transparent border-0 outline-none text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-600"
      />
    </div>

    {allCategories.length > 0 && (
      <div id="cat-filter-wrap" class="px-4 py-3 border-t border-gray-100 dark:border-gray-800">
        <button
          id="cat-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="cat-panel"
          class="flex items-center gap-1.5 text-base text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-colors cursor-pointer select-none"
        >
          <span>Category</span>
          <span id="cat-selected-label" class="text-blue-500 hidden"></span>
          <span id="cat-arrow" aria-hidden="true">▾</span>
        </button>
        <div
          id="cat-panel"
          role="group"
          aria-label="Category filter"
          class="hidden flex-wrap gap-1.5 mt-2.5"
        >
          <button
            data-cat="__all__"
            type="button"
            class="filter-cat-btn text-base px-3 py-1 rounded-full border border-gray-200 dark:border-gray-700 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:border-gray-400 dark:hover:border-gray-500 transition-colors cursor-pointer whitespace-nowrap"
          >
            All
          </button>
          {allCategories.map((cat) => (
            <button
              data-cat={cat}
              type="button"
              class="filter-cat-btn text-base px-3 py-1 rounded-full border border-gray-200 dark:border-gray-700 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:border-gray-400 dark:hover:border-gray-500 transition-colors cursor-pointer whitespace-nowrap"
            >
              {cat} <span class="text-gray-300 dark:text-gray-600">{catCounts.get(cat)}</span>
            </button>
          ))}
        </div>
      </div>
    )}

  </div>

  <p id="filter-status" aria-live="polite" class="text-base text-gray-400 mt-3 mb-2 empty:hidden"></p>

  <!-- 연도 점프: 포스트 목록의 목차, browse 모드에서만 표시 -->
  <nav id="year-nav" aria-label="Jump to year" class="flex flex-wrap gap-x-5 gap-y-1 mb-8 mt-4">
    {years.map((year) => (
      <a
        href={`#year-${year}`}
        class="text-base text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors no-underline"
      >
        {year}
      </a>
    ))}
  </nav>

  <!-- Browse 뷰: 연도별 포스트 목록 -->
  <div id="browse-view">
    {years.map((year) => {
      const posts = byYear.get(year)!;
      return (
        <section id={`year-${year}`} class="year-section mb-12 scroll-mt-20">
          <div class="flex items-center gap-3 mb-4">
            <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 m-0">{year}</h2>
            <span class="text-base text-gray-400 font-normal">{posts.length}</span>
            <div class="flex-1 h-px bg-gray-100 dark:bg-gray-800"></div>
          </div>

          <ul class="list-none p-0 m-0">
            {posts.map((post) => {
              const [postYear, postNum] = post.slug.split('/');
              const searchText = [
                post.data.title,
                post.data.category,
                post.data.description,
              ].filter(Boolean).join(' ').toLowerCase();
              return (
                <li
                  class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-6 py-3.5 border-b border-gray-100 dark:border-gray-800 last:border-b-0"
                  data-cat={post.data.category || ''}
                  data-search={searchText}
                >
                  <span class="sm:w-20 sm:flex-shrink-0 text-base text-gray-400 tabular-nums pt-px">
                    {formatDate(post.data.date)}
                  </span>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-baseline gap-2.5 flex-wrap">
                      <a
                        href={`${base}/itmir/${postYear}/${postNum}/`}
                        class="text-base font-semibold text-gray-900 dark:text-gray-100 hover:text-blue-600 dark:hover:text-blue-400 no-underline transition-colors"
                      >
                        {post.data.title}
                      </a>
                      {post.data.category && (
                        <span class="text-base text-gray-400 whitespace-nowrap flex-shrink-0">
                          {post.data.category}
                        </span>
                      )}
                    </div>
                    {post.data.description && (
                      <p class="text-base text-gray-400 m-0 mt-0.5 leading-snug">
                        {post.data.description}
                      </p>
                    )}
                  </div>
                </li>
              );
            })}
          </ul>
        </section>
      );
    })}
  </div>

  <!-- Search 뷰: Pagefind 결과 -->
  <div id="search-view" class="hidden">
    <p id="search-result-count" class="text-base text-gray-400 mb-6"></p>
    <ul id="search-result-list" class="list-none p-0 m-0 space-y-6"></ul>
    <p id="search-no-results" class="hidden text-base text-gray-400">No results.</p>
  </div>
</BaseLayout>

<style>
  .filter-cat-btn.active {
    @apply bg-blue-600 border-blue-600 text-white;
  }
</style>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const catBtns = document.querySelectorAll<HTMLButtonElement>('.filter-cat-btn');
  const allItems = document.querySelectorAll<HTMLLIElement>('li[data-search]');
  const yearSections = document.querySelectorAll<HTMLElement>('section[id^="year-"]');
  const filterStatus = document.getElementById('filter-status');
  const catToggle = document.getElementById('cat-toggle') as HTMLButtonElement | null;
  const catPanel = document.getElementById('cat-panel') as HTMLElement | null;
  const catArrow = document.getElementById('cat-arrow') as HTMLElement | null;
  const catSelectedLabel = document.getElementById('cat-selected-label') as HTMLElement | null;
  const catFilterWrap = document.getElementById('cat-filter-wrap') as HTMLElement | null;
  const yearNav = document.getElementById('year-nav') as HTMLElement | null;
  const browseView = document.getElementById('browse-view') as HTMLElement | null;
  const searchView = document.getElementById('search-view') as HTMLElement | null;
  const searchResultList = document.getElementById('search-result-list') as HTMLElement | null;
  const searchResultCount = document.getElementById('search-result-count') as HTMLElement | null;
  const searchNoResults = document.getElementById('search-no-results') as HTMLElement | null;

  const base = import.meta.env.BASE_URL.replace(/\/$/, '');

  let selectedCats = new Set<string>();
  let query = '';
  let panelOpen = false;

  // Pagefind 지연 초기화
  let pf: any = null;
  let pfReady = false;
  async function getPagefind() {
    if (pfReady) return pf;
    try {
      // @ts-ignore — pagefind은 빌드 후 런타임에만 존재
      pf = await import(/* @vite-ignore */ `${base}/pagefind/pagefind.js`);
      await pf.init();
      pfReady = true;
    } catch {
      pfReady = false;
      pf = null;
    }
    return pf;
  }

  function setMode(newMode: 'browse' | 'search') {
    const isSearch = newMode === 'search';
    browseView?.classList.toggle('hidden', isSearch);
    searchView?.classList.toggle('hidden', !isSearch);
    yearNav?.classList.toggle('hidden', isSearch);
    if (catFilterWrap) catFilterWrap.style.display = isSearch ? 'none' : '';
    if (filterStatus && isSearch) filterStatus.textContent = '';
  }

  function setPanelOpen(open: boolean) {
    panelOpen = open;
    if (catPanel) {
      catPanel.classList.toggle('hidden', !open);
      catPanel.classList.toggle('flex', open);
    }
    if (catArrow) catArrow.textContent = open ? '▴' : '▾';
    if (catToggle) catToggle.setAttribute('aria-expanded', String(open));
  }

  function updateSelectedLabel() {
    if (!catSelectedLabel) return;
    if (selectedCats.size === 0) {
      catSelectedLabel.textContent = '';
      catSelectedLabel.classList.add('hidden');
    } else {
      catSelectedLabel.textContent = `(${selectedCats.size} selected)`;
      catSelectedLabel.classList.remove('hidden');
    }
  }

  function readURL() {
    const p = new URLSearchParams(window.location.search);
    const c = p.get('cat');
    if (c) selectedCats = new Set(c.split(',').filter(Boolean));
    query = p.get('q') || '';
  }

  function pushURL() {
    const p = new URLSearchParams();
    if (selectedCats.size > 0) p.set('cat', [...selectedCats].join(','));
    if (query) p.set('q', query);
    const qs = p.toString();
    history.replaceState(null, '', location.pathname + (qs ? '?' + qs : ''));
  }

  function applyBrowseFilter() {
    let visible = 0;
    allItems.forEach((li) => {
      const catMatch = selectedCats.size === 0 || selectedCats.has(li.dataset.cat || '');
      const show = catMatch;
      li.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    yearSections.forEach((sec) => {
      const any = Array.from(sec.querySelectorAll<HTMLLIElement>('li[data-search]')).some(
        (li) => li.style.display !== 'none',
      );
      sec.style.display = any ? '' : 'none';
    });
    const filtered = selectedCats.size > 0;
    if (filterStatus) filterStatus.textContent = filtered ? `${visible} shown` : '';
    updateSelectedLabel();
    pushURL();
  }

  function renderSearchResults(results: any[]) {
    if (!searchResultList || !searchResultCount || !searchNoResults) return;
    if (results.length === 0) {
      searchResultList.innerHTML = '';
      searchNoResults.classList.remove('hidden');
      searchResultCount.textContent = '';
      return;
    }
    searchNoResults.classList.add('hidden');
    searchResultCount.textContent = `${results.length} results`;
    searchResultList.innerHTML = results.map((item) => {
      const href = item.url;
      const title = item.meta?.title || 'Untitled';
      const excerpt = item.excerpt || '';
      return `<li class="border-b border-gray-100 dark:border-gray-800 pb-6 last:border-b-0">
        <a href="${href}" class="text-base font-semibold text-gray-900 dark:text-gray-100 hover:text-blue-600 dark:hover:text-blue-400 no-underline transition-colors block mb-1">${title}</a>
        <p class="text-base text-gray-500 dark:text-gray-400 m-0 leading-relaxed">${excerpt}</p>
      </li>`;
    }).join('');
  }

  async function runSearch(q: string) {
    if (q.length < 2) {
      setMode('browse');
      applyBrowseFilter();
      return;
    }
    setMode('search');
    pushURL();

    const engine = await getPagefind();
    if (!engine) {
      // Pagefind 미사용 시 (개발 환경) — 제목 필터로 대체
      if (searchResultCount) searchResultCount.textContent = '';
      if (searchNoResults) {
        searchNoResults.textContent = 'Full-text search is available after build.';
        searchNoResults.classList.remove('hidden');
      }
      return;
    }

    const result = await engine.search(q);
    const data = await Promise.all(result.results.slice(0, 30).map((r: any) => r.data()));
    renderSearchResults(data);
  }

  function syncUI() {
    catBtns.forEach((btn) => {
      const c = btn.dataset.cat;
      btn.classList.toggle('active', c === '__all__' ? selectedCats.size === 0 : selectedCats.has(c!));
    });
  }

  readURL();
  if (searchInput) searchInput.value = query;
  if (selectedCats.size > 0) setPanelOpen(true);
  syncUI();

  if (query.length >= 2) {
    runSearch(query);
  } else {
    applyBrowseFilter();
  }

  catToggle?.addEventListener('click', () => setPanelOpen(!panelOpen));
  catBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const c = btn.dataset.cat;
      if (c === '__all__') selectedCats.clear();
      else if (c) selectedCats.has(c) ? selectedCats.delete(c) : selectedCats.add(c);
      syncUI();
      applyBrowseFilter();
    });
  });

  let debounce: ReturnType<typeof setTimeout>;
  searchInput?.addEventListener('input', () => {
    clearTimeout(debounce);
    debounce = setTimeout(() => {
      query = searchInput!.value.toLowerCase().trim();
      runSearch(query);
    }, 300);
  });
</script>
