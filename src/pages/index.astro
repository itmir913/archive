---
import '../styles/global.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="ko" class="antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="luminousky digital archive" />
    <title>luminousky / archive</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.css"
    />
  </head>
  <body class="min-h-screen flex items-center justify-center bg-white font-sans">
    <main class="w-full max-w-5xl px-6 py-8">
      <header class="mb-12">
        <p class="text-base font-medium tracking-widest uppercase text-gray-400 m-0 mb-1">
          luminousky
        </p>
        <h1 class="text-4xl font-bold tracking-tighter text-gray-900 m-0 leading-none">
          archive
        </h1>
      </header>

      <div class="flex flex-col border-t border-gray-200">
        <a
          href={`${base}/itmir/`}
          class="group flex items-center justify-between px-0 py-6 border-b border-gray-200 no-underline"
        >
          <div class="flex items-baseline gap-4">
            <span class="text-base font-semibold tracking-widest uppercase text-gray-400 whitespace-nowrap">
              Chapter 1
            </span>
            <span class="text-xl font-semibold tracking-tight text-gray-900 group-hover:text-blue-600 transition-colors">
              ITMir
            </span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-base text-gray-400">2012 – 2021</span>
            <span class="text-base text-gray-400 group-hover:translate-x-1 group-hover:text-blue-600 transition-all duration-150">
              →
            </span>
          </div>
        </a>

        <div class="flex items-center justify-between px-0 py-6 border-b border-gray-200 cursor-default">
          <div class="flex items-baseline gap-4">
            <span class="text-base font-semibold tracking-widest uppercase text-gray-200 whitespace-nowrap">
              Chapter 2
            </span>
            <span class="text-xl font-semibold tracking-tight text-gray-200">
              luminousky
            </span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-base text-gray-400">coming soon</span>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
