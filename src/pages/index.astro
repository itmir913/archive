---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allPosts = await getCollection('itmir', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recent = allPosts.slice(0, 6);

function shortDate(d: Date) {
  return d.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'Asia/Seoul',
  });
}
---

<BaseLayout title="Archive">
  <!-- Hero -->
  <div class="mb-16">
    <h1 class="text-4xl font-bold tracking-tight m-0 mb-3">Archive</h1>
    <p class="text-base text-gray-500 m-0 max-w-lg leading-relaxed">
      2012년부터 지금까지의 개발 기록. 블로그, 프로젝트, 그리고 앞으로 작성할 글 모두 여기 있습니다.
    </p>
  </div>

  <!-- Chapters -->
  <div class="grid sm:grid-cols-2 gap-4 mb-14">
    <a
      href={`${base}/itmir/`}
      class="group block p-6 rounded-2xl border border-gray-200 hover:border-blue-200 hover:bg-blue-50/40 transition-all no-underline"
    >
      <p class="text-base text-blue-500 font-medium m-0 mb-1.5">Chapter 1</p>
      <h2 class="text-xl font-bold text-gray-900 m-0 mb-3 group-hover:text-blue-700 transition-colors">
        ITMir
      </h2>
      <p class="text-base text-gray-500 m-0 mb-2">2012 – 2021</p>
      <p class="text-base text-gray-400 m-0">{allPosts.length}개 포스트</p>
    </a>

    <div class="p-6 rounded-2xl border border-gray-100 bg-gray-50/60">
      <p class="text-base text-violet-300 font-medium m-0 mb-1.5">Chapter 2</p>
      <h2 class="text-xl font-bold text-gray-300 m-0 mb-3">luminousky</h2>
      <p class="text-base text-gray-400 m-0 mb-2">2026 –</p>
      <p class="text-base text-gray-300 m-0">곧 공개</p>
    </div>
  </div>

  <!-- Timeline -->
  <a
    href={`${base}/timeline/`}
    class="group flex items-center justify-between p-6 rounded-2xl border border-gray-200 hover:border-gray-300 hover:bg-gray-50 transition-all no-underline mb-14"
  >
    <div>
      <h2 class="text-xl font-bold text-gray-900 m-0 mb-2 group-hover:text-blue-700 transition-colors">
        Timeline
      </h2>
      <p class="text-base text-gray-500 m-0">
        2012년부터 지금까지의 핵심 전환점 — 성장의 서사
      </p>
    </div>
    <span class="text-base text-gray-400 group-hover:text-blue-500 group-hover:translate-x-1 transition-all flex-shrink-0 ml-6">
      →
    </span>
  </a>

  <!-- Recent -->
  <div>
    <h2 class="text-base font-semibold text-gray-400 uppercase tracking-widest m-0 mb-5">
      최근 포스트
    </h2>
    <ul class="list-none p-0 m-0 divide-y divide-gray-100">
      {recent.map((post) => {
        const [year, num] = post.slug.split('/');
        return (
          <li class="py-4 flex gap-6 items-baseline">
            <span class="text-base text-gray-400 whitespace-nowrap tabular-nums flex-shrink-0 w-28">
              {shortDate(post.data.date)}
            </span>
            <a
              href={`${base}/itmir/${year}/${num}/`}
              class="text-base font-medium text-gray-900 hover:text-blue-600 no-underline transition-colors"
            >
              {post.data.title}
            </a>
          </li>
        );
      })}
    </ul>
    <div class="mt-5">
      <a
        href={`${base}/itmir/`}
        class="text-base text-blue-500 hover:text-blue-700 no-underline transition-colors"
      >
        전체 {allPosts.length}개 보기 →
      </a>
    </div>
  </div>
</BaseLayout>
