---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  maxWidth?: string;
}

const { title, description = 'ITMir 아카이브 · 2012–2021 · luminousky', maxWidth } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} — luminousky archive</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.css"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href={`${base}/`} class="site-title">luminousky / ITMir</a>
        <span class="site-period">2012 – 2021</span>
      </div>
    </header>

    <main>
      <div class="content-wrapper" style={maxWidth ? `max-width: ${maxWidth}` : undefined}>
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <p>
        Originally published on{' '}
        <a href="https://itmir.tistory.com" target="_blank" rel="noopener noreferrer">
          itmir.tistory.com
        </a>
        {' '}· Archived by luminousky
      </p>
    </footer>
  </body>
</html>
