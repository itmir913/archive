---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  section?: 'archive' | 'timeline';
  pagefindIgnore?: boolean;
}

const {
  title,
  description = 'luminousky · 2012–',
  section,
  pagefindIgnore = false,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalUrl = `https://luminousky.com${Astro.url.pathname}`;
const fullTitle = `${title} — luminousky`;

function navLink(s: 'archive' | 'timeline') {
  const active = section === s;
  return active
    ? 'text-base font-medium text-gray-900 dark:text-gray-100 no-underline px-3 py-1.5 rounded-md bg-gray-100 dark:bg-gray-800 transition-colors'
    : 'text-base font-medium text-gray-400 dark:text-gray-500 no-underline px-3 py-1.5 rounded-md hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors';
}
---

<!DOCTYPE html>
<html lang="ko" class="antialiased scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>

    <!-- 다크모드 FOUC 방지 — 렌더링 전 클래스 적용 -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (t === 'dark' || (!t && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!-- OG / Twitter 메타태그 -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="luminousky" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.css"
    />
  </head>
  <body class="bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 font-sans min-h-screen flex flex-col transition-colors">

    <header class="sticky top-0 z-50 bg-white/90 dark:bg-gray-950/90 backdrop-blur-md border-b border-black/[0.06] dark:border-white/[0.06]">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
        <a
          href={`${base}/`}
          class="text-base font-semibold tracking-tight text-gray-900 dark:text-gray-100 no-underline hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
        >
          luminousky
        </a>
        <nav class="flex items-center gap-1">
          <a href={`${base}/`} class={navLink('archive')}>Archive</a>
          <a href={`${base}/timeline/`} class={navLink('timeline')}>Timeline</a>
          <button
            id="theme-toggle"
            aria-label="다크 모드 전환"
            class="ml-1 p-2 rounded-md text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-colors"
          >
            <!-- 라이트 모드에서 표시 (달 아이콘 → 다크로 전환) -->
            <svg id="icon-moon" class="w-5 h-5 dark:hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
            <!-- 다크 모드에서 표시 (해 아이콘 → 라이트로 전환) -->
            <svg id="icon-sun" class="w-5 h-5 hidden dark:block" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main class="flex-1" data-pagefind-ignore={pagefindIgnore ? 'all' : undefined}>
      <div class="max-w-5xl mx-auto px-6 py-14">
        <slot />
      </div>
    </main>

    <footer class="border-t border-gray-100 dark:border-gray-800 mt-auto">
      <div class="max-w-5xl mx-auto px-6 py-8 flex items-center justify-end gap-6">
        <a
          href="https://luminousky.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-base text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 no-underline transition-colors"
        >
          luminousky.com ↗
        </a>
        <a
          href="https://github.com/itmir913"
          target="_blank"
          rel="noopener noreferrer"
          class="text-base text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 no-underline transition-colors"
        >
          GitHub ↗
        </a>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('theme-toggle');
      btn?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    </script>

  </body>
</html>
