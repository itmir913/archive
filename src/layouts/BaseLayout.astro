---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'ITMir 아카이브 · 2013–2021 · luminousky' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} — luminousky archive</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href={`${base}/`} class="site-title">luminousky / ITMir</a>
        <span class="site-period">2013 – 2021</span>
      </div>
    </header>

    <main>
      <div class="content-wrapper">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <p>
        Originally published on{' '}
        <a href="https://itmir.tistory.com" target="_blank" rel="noopener noreferrer">
          itmir.tistory.com
        </a>
        {' '}· Archived by luminousky
      </p>
    </footer>
  </body>
</html>
