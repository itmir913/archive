---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  section?: 'archive' | 'timeline';
}

const {
  title,
  description = 'luminousky · 2012–',
  section,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function navLink(s: 'archive' | 'timeline') {
  const active = section === s;
  return active
    ? 'text-base font-medium text-gray-900 no-underline px-3 py-1.5 rounded-md bg-gray-100 transition-colors'
    : 'text-base font-medium text-gray-400 no-underline px-3 py-1.5 rounded-md hover:text-gray-900 hover:bg-gray-50 transition-colors';
}
---

<!DOCTYPE html>
<html lang="ko" class="antialiased scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} — luminousky</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.css"
    />
  </head>
  <body class="bg-white text-gray-900 font-sans min-h-screen flex flex-col">

    <header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-black/[0.06]">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
        <a
          href={`${base}/`}
          class="text-base font-semibold tracking-tight text-gray-900 no-underline hover:text-blue-600 transition-colors"
        >
          luminousky
        </a>
        <nav class="flex items-center gap-1">
          <a href={`${base}/`} class={navLink('archive')}>Archive</a>
          <a href={`${base}/timeline/`} class={navLink('timeline')}>Timeline</a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <div class="max-w-5xl mx-auto px-6 py-14">
        <slot />
      </div>
    </main>

    <footer class="border-t border-gray-100 mt-auto">
      <div class="max-w-5xl mx-auto px-6 py-8 flex items-center justify-between">
        <span class="text-base text-gray-400">luminousky · 2012 –</span>
        <div class="flex items-center gap-5">
          <a
            href="https://luminousky.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-base text-gray-400 hover:text-gray-700 no-underline transition-colors"
          >
            @luminousky
          </a>
          <a
            href="https://github.com/itmir913"
            target="_blank"
            rel="noopener noreferrer"
            class="text-base text-gray-400 hover:text-gray-700 no-underline transition-colors"
          >
            GitHub ↗
          </a>
        </div>
      </div>
    </footer>

  </body>
</html>
